# ---- Postgres ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=mediflow
POSTGRES_USER=mediflow
POSTGRES_PASSWORD=changeme-in-vault
# pgcrypto symmetric key — fetched from Vault in prod, set here for local dev only
MEDIFLOW_ENC_KEY=dev-only-32char-key-change-me-00

# ---- Airflow ----
AIRFLOW__CORE__FERNET_KEY=generate-with-cryptography-fernet
AIRFLOW__WEBSERVER__SECRET_KEY=dev-secret
AIRFLOW_ADMIN_PASSWORD=changeme
AIRFLOW__CELERY__BROKER_URL=redis://redis:6379/0

# ---- Superset ----
SUPERSET_SECRET_KEY=dev-secret-change-me

# ---- Keycloak ----
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme
KEYCLOAK_SUPERSET_CLIENT_SECRET=set-after-realm-import

# ---- Vault ----
VAULT_ADDR=http://vault:8200
VAULT_ROLE_ID=approle-role-id
VAULT_SECRET_ID=approle-secret-id

# ---- Pseudonymisation ----
# HMAC key lives in Vault at secret/mediflow/hmac; this is the dev fallback
MEDIFLOW_HMAC_KEY=dev-only-hmac-key

# ---- Alerting ----
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=alerts@example.com
SMTP_PASSWORD=changeme

# ---- Grafana ----
GRAFANA_ADMIN_PASSWORD=changeme
